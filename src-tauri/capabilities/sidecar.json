{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "sidecar",
  "description": "Permission to execute the pdfdiff sidecar binary with restricted arguments",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "pdfdiff",
          "sidecar": true,
          "args": [
            {
              "validator": "regex",
              "value": "^(diff|validate|annotate|visual-diff|detect|--json|--dpi|--word-spacing-factor|--annotations|[\\d.]+|/.+\\.pdf|[A-Za-z]:\\\\.+\\.pdf)$"
            }
          ]
        }
      ]
    }
  ]
}
